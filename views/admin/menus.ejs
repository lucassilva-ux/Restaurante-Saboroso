<%- include('inc/headers') -%>

    <div class="content-wrapper">
      <section class="content-header">
        <h1>Menu</h1>
        <ol class="breadcrumb">
          <li><a href="/"><i class="fa fa-home"></i> Home</a></li>
          <li class="active">Menu</li>
        </ol>
      </section>

      <section class="content container-fluid">

        <div class="box">
          <div class="box-header">
            <h3 class="box-title">Lista</h3>
            <a href="#" class="btn btn-xs pull-right btn-success" data-toggle="modal" data-target="#modal-create">
              <i class="fa fa-plus"></i> Novo
            </a>
          </div>
          <div class="box-body no-padding">
            <table class="table table-striped table-hover">
              <thead>
                <tr>
                  <th style="width: 10px">#</th>
                  <th>Foto</th>
                  <th>Titulo</th>
                  <th>Descricao</th>
                  <th>Preco</th>
                  <th style="min-width: 134px;">Acoes</th>
                </tr>
              </thead>
              <tbody>
                <% data.forEach(function(row){ %>
                <tr data-row='<%- JSON.stringify(row).replace(/'/g, "&#39;") %>'>
                  <td><%= row.id %></td>
                  <td><img src="/<%= row.photo %>" alt="" style="height: 18px;"></td>
                  <td><%= row.title %></td>
                  <td><%= row.description %></td>
                  <td><%= row.price %></td>
                  <td>
                    <button type="button" class="btn btn-xs btn-info btn-update" data-toggle="modal" data-target="#modal-update">
                      <i class="fa fa-pencil"></i> Editar
                    </button>&nbsp;
                    <button type="button" class="btn btn-xs btn-danger btn-delete">
                      <i class="fa fa-trash"></i> Excluir
                    </button>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <%- include('inc/pagination', { pagination: pagination }) %>
        </div>

      </section>
    </div>

    <div class="modal fade" id="modal-create">
      <div class="modal-dialog">
        <div class="modal-content" style="border-top: 3px solid #00a65a;">
          <form id="modal-create-form" method="post" enctype="multipart/form-data" action="/admin/menus">
            <div class="modal-header">
              <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
              </button>
              <h4 class="modal-title">Novo Menu</h4>
            </div>
            <div class="modal-body">
              <div class="form-group">
                <label for="inputTitleCreate">Titulo</label>
                <input type="text" class="form-control" id="inputTitleCreate" name="title">
              </div>
              <div class="form-group">
                <label for="inputDescriptionCreate">Descricao</label>
                <textarea class="form-control" id="inputDescriptionCreate" name="description"></textarea>
              </div>
              <div class="form-group">
                <label for="inputPriceCreate">Preco</label>
                <input type="number" class="form-control" id="inputPriceCreate" name="price">
              </div>
              <div class="form-group">
                <label for="inputPhotoCreate">Foto</label>
                <img id="previewPhotoCreate" style="max-width: 128px; max-height: 128px; display: block; margin-bottom: 10px;" src="/admin/dist/img/boxed-bg.jpg">
                <input type="file" class="form-control" id="inputPhotoCreate" name="photo">
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-default pull-left" data-dismiss="modal">Cancelar</button>
              <button type="submit" class="btn btn-success">Salvar</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="modal fade" id="modal-update">
      <div class="modal-dialog">
        <div class="modal-content" style="border-top: 3px solid #00c0ef;">
          <form id="modal-update-form" method="post" enctype="multipart/form-data" action="/admin/menus/update">
            <input type="hidden" name="id">
            <input type="hidden" name="currentPhoto">
            <div class="modal-header">
              <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
              </button>
              <h4 class="modal-title">Editar Menu</h4>
            </div>
            <div class="modal-body">
              <div class="form-group">
                <label for="inputTitleUpdate">Titulo</label>
                <input type="text" class="form-control" id="inputTitleUpdate" name="title">
              </div>
              <div class="form-group">
                <label for="inputDescriptionUpdate">Descricao</label>
                <textarea class="form-control" id="inputDescriptionUpdate" name="description"></textarea>
              </div>
              <div class="form-group">
                <label for="inputPriceUpdate">Preco</label>
                <input type="number" class="form-control" id="inputPriceUpdate" name="price">
              </div>
              <div class="form-group">
                <label for="inputPhotoUpdate">Foto</label>
                <img id="previewPhotoUpdate" style="max-width: 128px; max-height: 128px; display: block; margin-bottom: 10px;" src="/admin/dist/img/boxed-bg.jpg">
                <input type="file" class="form-control" id="inputPhotoUpdate" name="photo">
                <p class="help-block">Deixe vazio para manter a foto atual.</p>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-default pull-left" data-dismiss="modal">Cancelar</button>
              <button type="submit" class="btn btn-info">Salvar alterações</button>
            </div>
          </form>
        </div>
      </div>
    </div>

<%- include('inc/footer') -%>
<script src="/js/hcode-filereader.js"></script>
<script src="/js/hcode-formsave.js"></script>
<script src="/js/hcode-grid.js"></script>
<script>
    new HcodeFileReader("#modal-create [type=file]", "#modal-create img");
    new HcodeFileReader("#modal-update [type=file]", "#modal-update img");

    new HcodeGrid({
        deleteUrl: '/admin/menus/${data.id}',
        deleteMsg: 'Deseja realmente excluir o menu ${data.title}?',
        onUpdateLoad: (form, name, data) => {

            let input = form.querySelector(`[name=${name}]`);

            switch (name) {

                case 'photo':
                    form.querySelector("[name=currentPhoto]").value = data[name];
                    form.querySelector("img").src = '/' + data[name];
                    break;

                default:
                    if (input) input.value = data[name];

            }

        }
    });
</script>
