<%- include('inc/headers') -%>

    <div class="content-wrapper">
      <section class="content-header">
        <h1>Menu</h1>
        <ol class="breadcrumb">
          <li><a href="/"><i class="fa fa-home"></i> Home</a></li>
          <li class="active">Menu</li>
        </ol>
      </section>

      <section class="content container-fluid">

        <div class="box">
          <div class="box-header">
            <h3 class="box-title">Lista</h3>
            <a href="#" class="btn btn-xs pull-right btn-success" data-toggle="modal" data-target="#modal-create">
              <i class="fa fa-plus"></i> Novo
            </a>
          </div>
          <div class="box-body no-padding">
            <table class="table table-striped table-hover">
              <thead>
                <tr>
                  <th style="width: 10px">#</th>
                  <th>Foto</th>
                  <th>Titulo</th>
                  <th>Descricao</th>
                  <th>Preco</th>
                  <th style="min-width: 134px;">Acoes</th>
                </tr>
              </thead>
              <tbody>
                <% data.forEach(function(row){ %>
                <tr data-row='<%- JSON.stringify(row).replace(/'/g, "&#39;") %>'>
                  <td><%= row.id %></td>
                  <td><img src="/<%= row.photo %>" alt="" style="height: 18px;"></td>
                  <td><%= row.title %></td>
                  <td><%= row.description %></td>
                  <td><%= row.price %></td>
                  <td>
                    <button type="button" class="btn btn-xs btn-info btn-update" data-toggle="modal" data-target="#modal-update">
                      <i class="fa fa-pencil"></i> Editar
                    </button>&nbsp;
                    <button type="button" class="btn btn-xs btn-danger btn-delete">
                      <i class="fa fa-trash"></i> Excluir
                    </button>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>

      </section>
    </div>

    <div class="modal fade" id="modal-create">
      <div class="modal-dialog">
        <div class="modal-content" style="border-top: 3px solid #00a65a;">
          <form id="modal-create-form" method="post" enctype="multipart/form-data">
            <div class="modal-header">
              <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
              </button>
              <h4 class="modal-title">Novo Menu</h4>
            </div>
            <div class="modal-body">
              <div class="form-group">
                <label for="inputTitleCreate">Titulo</label>
                <input type="text" class="form-control" id="inputTitleCreate" name="title">
              </div>
              <div class="form-group">
                <label for="inputDescriptionCreate">Descricao</label>
                <textarea class="form-control" id="inputDescriptionCreate" name="description"></textarea>
              </div>
              <div class="form-group">
                <label for="inputPriceCreate">Preco</label>
                <input type="number" class="form-control" id="inputPriceCreate" name="price">
              </div>
              <div class="form-group">
                <label for="inputPhotoCreate">Foto</label>
                <img id="previewPhotoCreate" style="max-width: 128px; max-height: 128px; display: block; margin-bottom: 10px;" src="dist/img/boxed-bg.jpg">
                <input type="file" class="form-control" id="inputPhotoCreate" name="photo">
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-default pull-left" data-dismiss="modal">Cancelar</button>
              <button type="submit" class="btn btn-success">Salvar</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="modal fade" id="modal-update">
      <div class="modal-dialog">
        <div class="modal-content" style="border-top: 3px solid #00c0ef;">
          <form id="modal-update-form" method="post" enctype="multipart/form-data">
            <input type="hidden" name="id">
            <input type="hidden" name="currentPhoto">
            <div class="modal-header">
              <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
              </button>
              <h4 class="modal-title">Editar Menu</h4>
            </div>
            <div class="modal-body">
              <div class="form-group">
                <label for="inputTitleUpdate">Titulo</label>
                <input type="text" class="form-control" id="inputTitleUpdate" name="title">
              </div>
              <div class="form-group">
                <label for="inputDescriptionUpdate">Descricao</label>
                <textarea class="form-control" id="inputDescriptionUpdate" name="description"></textarea>
              </div>
              <div class="form-group">
                <label for="inputPriceUpdate">Preco</label>
                <input type="number" class="form-control" id="inputPriceUpdate" name="price">
              </div>
              <div class="form-group">
                <label for="inputPhotoUpdate">Foto</label>
                <img id="previewPhotoUpdate" style="max-width: 128px; max-height: 128px; display: block; margin-bottom: 10px;" src="dist/img/boxed-bg.jpg">
                <input type="file" class="form-control" id="inputPhotoUpdate" name="photo">
                <p class="help-block">Deixe vazio para manter a foto atual.</p>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-default pull-left" data-dismiss="modal">Cancelar</button>
              <button type="submit" class="btn btn-info">Salvar alterações</button>
            </div>
          </form>
        </div>
      </div>
    </div>

<%- include('inc/footer') -%>

<script>
  let formCreate = document.querySelector('#modal-create-form');
  let formUpdate = document.querySelector('#modal-update-form');
  let inputPhotoCreate = document.querySelector('#inputPhotoCreate');
  let inputPhotoUpdate = document.querySelector('#inputPhotoUpdate');
  let previewPhotoCreate = document.querySelector('#previewPhotoCreate');
  let previewPhotoUpdate = document.querySelector('#previewPhotoUpdate');
  let updateButtons = document.querySelectorAll('.btn-update');
  let deleteButtons = document.querySelectorAll('.btn-delete');
  let defaultCreatePhoto = previewPhotoCreate.src;
  let currentUpdatePhoto = previewPhotoUpdate.src;

  function parseRow(button) {
      return JSON.parse(button.closest('tr').dataset.row);
  }

  function parseResponse(response) {
      const contentType = response.headers.get('content-type') || '';

      if (contentType.includes('application/json')) {
          return response.json().then(payload => ({ response, payload }));
      }

      return response.text().then(text => ({ response, payload: { error: text } }));
  }

  function updateImagePreview(input, preview, fallbackSrc) {
      let file = input.files && input.files[0];

      if (!file) {
          preview.src = fallbackSrc;
          return;
      }

      preview.src = URL.createObjectURL(file);
  }

  inputPhotoCreate.addEventListener('change', () => {
      updateImagePreview(inputPhotoCreate, previewPhotoCreate, defaultCreatePhoto);
  });

  inputPhotoUpdate.addEventListener('change', () => {
      updateImagePreview(inputPhotoUpdate, previewPhotoUpdate, currentUpdatePhoto);
  });

  formCreate.addEventListener('submit', e => {
      e.preventDefault();

      let formCreateData = new FormData(formCreate);

      fetch('/admin/menus', {
          method: 'POST',
          body: formCreateData
      })
      .then(parseResponse)
      .then(({ response, payload }) => {
          if (!response.ok) {
              throw new Error(payload.error || 'Nao foi possivel salvar o menu.');
          }

          window.location.reload();
      })
      .catch(err => {
          alert(err.message || 'Nao foi possivel salvar o menu.');
      });
  });

  updateButtons.forEach(button => {
      button.addEventListener('click', () => {
          const row = parseRow(button);

          formUpdate.querySelector('[name=id]').value = row.id;
          formUpdate.querySelector('[name=title]').value = row.title;
          formUpdate.querySelector('[name=description]').value = row.description;
          formUpdate.querySelector('[name=price]').value = row.price;
          formUpdate.querySelector('[name=currentPhoto]').value = row.photo;
          currentUpdatePhoto = '/' + row.photo;
          previewPhotoUpdate.src = currentUpdatePhoto;
          inputPhotoUpdate.value = '';
      });
  });

  formUpdate.addEventListener('submit', e => {
      e.preventDefault();

      let formUpdateData = new FormData(formUpdate);

      fetch('/admin/menus/update', {
          method: 'POST',
          body: formUpdateData
      })
      .then(parseResponse)
      .then(({ response, payload }) => {
          if (!response.ok) {
              throw new Error(payload.error || 'Nao foi possivel atualizar o menu.');
          }

          window.location.reload();
      })
      .catch(err => {
          alert(err.message || 'Nao foi possivel atualizar o menu.');
      });
  });

  deleteButtons.forEach(button => {
      button.addEventListener('click', () => {
          const row = parseRow(button);

          if (!confirm(`Deseja excluir o menu "${row.title}"?`)) {
              return;
          }

          fetch('/admin/menus/delete', {
              method: 'POST',
              headers: {
                  'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
              },
              body: new URLSearchParams({
                  id: row.id
              })
          })
          .then(parseResponse)
          .then(({ response, payload }) => {
              if (!response.ok) {
                  throw new Error(payload.error || 'Nao foi possivel excluir o menu.');
              }

              window.location.reload();
          })
          .catch(err => {
              alert(err.message || 'Nao foi possivel excluir o menu.');
          });
      });
  });
</script>
